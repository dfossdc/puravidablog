NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# Anthropic API key for the AI chat widget at /api/chat. Without this, the chat
# widget gracefully shows a fallback message pointing to the phone + booking
# link. Get a key at https://console.anthropic.com/. Add to Vercel project env
# vars (puravidasanantonio.com → Settings → Environment Variables).
ANTHROPIC_API_KEY=

# Shared secret for the /api/indexnow endpoint (POST URLs to nudge Bing/Yandex
# IndexNow). Pick a random string and add it to Vercel env vars. Without this,
# the endpoint refuses all requests (fail-closed). The key file itself is
# public at /afa1c26c00c445aa95dc1ccbb8bfea99.txt — that's required by the
# IndexNow protocol and is not sensitive.
INDEXNOW_API_TOKEN=

# Vercel auto-injects this for cron route invocations and uses it to
# authenticate requests to /api/cron/* routes. You don't normally set this
# yourself — Vercel manages it. If you do define it manually (e.g. for testing
# the cron route via curl), match what Vercel uses or override CRON_SECRET in
# your project settings.
# CRON_SECRET=
